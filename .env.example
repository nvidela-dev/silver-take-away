# --- Database (NeonDB) ---
# Get this from your Neon project dashboard. The serverless driver expects an
# HTTP/WebSocket-ready pooled connection string.
DATABASE_URL=

# --- Clerk auth ---
# Set these in both local `.env.local` and Vercel project env vars.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/bills
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/bills

# Webhook signature secret from Clerk webhook settings.
CLERK_WEBHOOK_SECRET=

# Optional: helpful for docs, callbacks, and diagnostics.
# Example: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=
