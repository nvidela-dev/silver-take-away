# --- Database (NeonDB) ---
# Get this from your Neon project dashboard. The serverless driver expects an
# HTTP/WebSocket-ready connection string (the standard postgres:// URL works).
DATABASE_URL=

# --- Clerk auth (wired in PR-1) ---
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/bills
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/bills

# Webhook signature secret from the Clerk dashboard's webhook settings.
CLERK_WEBHOOK_SECRET=
