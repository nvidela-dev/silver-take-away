# --- Database (NeonDB) ---
# Get this from your Neon project dashboard. The serverless driver expects an
# HTTP/WebSocket-ready pooled connection string.
# Use the pooled connection string for Vercel/serverless deployments.
# Example:
# DATABASE_URL=postgresql://neondb_owner:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Optional: helpful for docs, callbacks, and diagnostics.
# Example: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=
